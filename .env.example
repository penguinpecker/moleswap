# PushChain
NEXT_PUBLIC_PUSHCHAIN_NETWORK=testnet

# Supabase (for leaderboard, quests, user data)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Relay Protocol (fallback liquidity until PushChain AMM is live)
NEXT_PUBLIC_RELAY_SOURCE=moleswap-pushchain

# Optional: WalletConnect (legacy fallback)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-project-id

# Site
NEXT_PUBLIC_SITE_URL=https://www.moleswap.com
